// 测试: 控制流 - 空循环
// 语法: whileStatement, forStatement
// 描述: 测试零次迭代的循环

int i = 10;
int whileCount = 0;
while (i < 5) {
    whileCount += 1;
    i = i + 1;
}
assert(whileCount == 0, "while should not execute");

int forCount = 0;
for (int j = 10, 4) {
    forCount += 1;
}
assert(forCount == 0, "for should not execute");

print("zero_iterations tests passed!");
