// 测试: 迭代 - pairs遍历
// 语法: forEachControl -> forEachVar (COMMA forEachVar)* COL expressionList
// 描述: 测试pairs迭代器遍历List和Map

list<any> l = [10, null, 30];
print("--- List ---");
for (k, v : pairs(l)) {
    if (v == null) {
        print(k .. ":nil");
    } else {
        print(k .. ":" .. v);
    }
}

map<int, int> m = {1:30, 3:30};
print("--- Map ---");
for (k, v : pairs(m)) {
    print(v);
}
