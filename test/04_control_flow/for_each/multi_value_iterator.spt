// 测试: 控制流 - 多变量for-each
// 语法: forEachControl
// 描述: 测试多返回值的for-each

int count = 0;
int sum = 0;

vars iter(any s, int c) {
    if (c < 3) {
        return c + 1, c * 10;
    }
    return null;
}

for (auto i, auto v : iter, null, 0) {
    count += 1;
    sum += v;
}
assert(count == 3, "should iterate 3 times");
assert(sum == 30, "sum should be 30 (0+10+20)");

print("multi_value_iterator tests passed!");
