// 测试: 控制流 - 泛型for迭代器
// 语法: forEachControl
// 描述: 测试自定义迭代器函数

int count = 0;

int iter(any s, int c) {
    if (c < 3) {
        return c + 1;
    }
    return null;
}

for (auto i : iter, null, 0) {
    count += 1;
}
assert(count == 3, "should iterate 3 times");

print("custom_iterator tests passed!");
