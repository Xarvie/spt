// 测试: 控制流 - 简单if-else
// 语法: ifStatement -> IF OP expression CP blockStatement ELSE blockStatement
// 描述: 测试简单的if-else语句

int x = 5;
str result = "";
if (x > 10) {
    result = "big";
} else {
    result = "small";
}
assert(result == "small", "result should be 'small'");

print("if_else_simple tests passed!");
