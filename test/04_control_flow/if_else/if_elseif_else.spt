// 测试: 控制流 - if/else语句
// 语法: ifStatement -> IF OP expression CP blockStatement (ELSE IF OP expression CP blockStatement)* (ELSE blockStatement)?
// 描述: 测试if-else if-else链

int x = 2;
str result = "";
if (x == 1) {
    result = "one";
} else if (x == 2) {
    result = "two";
} else if (x == 3) {
    result = "three";
} else {
    result = "other";
}
assert(result == "two", "result should be 'two'");

print("if_elseif_else tests passed!");
