// 测试: 类型系统 - 类名作为类型
// 语法: type -> qualifiedIdentifier
// 描述: 测试使用类名作为类型注解

class Point {
    int x;
    int y;
    void __init(int x, int y) {
        this.x = x;
        this.y = y;
    }
}

Point p = Point(10, 20);
assert(p.x == 10, "p.x should be 10");
assert(p.y == 20, "p.y should be 20");

print("class_as_type tests passed!");
