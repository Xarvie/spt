// 测试: 类型系统 - List类型
// 语法: listType -> LIST (LT type GT)?
// 描述: 测试List类型注解

list a = [1, 2];
list<int> b = [3, 4];
list<list<int>> c = [[5]];
assert(a[0] == 1, "a[0] should be 1");
assert(b[1] == 4, "b[1] should be 4");
assert(c[0][0] == 5, "c[0][0] should be 5");

print("list_type tests passed!");
