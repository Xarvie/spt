// 测试: 类型系统 - 嵌套list类型
// 语法: listType -> LIST (LT type GT)?
// 描述: 测试list<map<str, int>>嵌套类型

list<map<str, int>> data = [
    {"x": 1, "y": 2},
    {"x": 3, "y": 4}
];

assert(data[0]["x"] == 1, "data[0]['x'] should be 1");
assert(data[1]["y"] == 4, "data[1]['y'] should be 4");

print("list_of_map_type tests passed!");
