// 测试: 类型系统 - 嵌套map类型
// 语法: mapType -> MAP (LT type COMMA type GT)?
// 描述: 测试map<str, list<int>>嵌套类型

map<str, list<int>> data = {
    "a": [1, 2, 3],
    "b": [4, 5, 6]
};

assert(data["a"][0] == 1, "data['a'][0] should be 1");
assert(data["b"][2] == 6, "data['b'][2] should be 6");

print("map_of_list_type tests passed!");
