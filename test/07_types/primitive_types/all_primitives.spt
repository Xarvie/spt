// 测试: 类型系统 - 基本类型
// 语法: primitiveType -> INT | FLOAT | NUMBER | str | BOOL | VOID | NULL_ | COROUTINE | FUNCTION
// 描述: 测试所有基本类型

int a = 1;
float b = 2.5;
number c = 3;
str d = "s";
bool e = true;
any f = null;
assert(a == 1, "a should be 1");
assert(b == 2.5, "b should be 2.5");
assert(c == 3, "c should be 3");
assert(d == "s", "d should be 's'");
assert(e == true, "e should be true");
assert(f == null, "f should be null");

print("all_primitives tests passed!");
