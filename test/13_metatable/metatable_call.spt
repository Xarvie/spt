// 测试: 元表 - __call
// 语法: metatable __call
// 描述: 测试元表__call元方法使表可调用

map<any, any> callable = {};
setmetatable(callable, {
    __call: function(map<any, any> self, int x, int y) -> int {
        return x + y;
    }
});

int result = callable(10, 20);
assert(result == 30, "callable(10, 20) should be 30");

print("metatable_call tests passed!");
