// 测试: Map - 动态行为
// 语法: mapExpression, postfixIndexSuffix
// 描述: 测试Map的动态扩容和任意键

map<any, any> m = {};
m[100] = 1;
m["k"] = "v";
assert(m[100] == 1, "m[100] should be 1");
assert(m["k"] == "v", "m['k'] should be 'v'");

m[1000] = 2;
assert(m[1000] == 2, "m[1000] should be 2");

print("map_dynamic tests passed!");
