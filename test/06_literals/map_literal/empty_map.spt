// 测试: 字面量 - 空Map
// 语法: mapExpression -> OCB mapEntryList? CCB
// 描述: 测试空Map字面量

map<str, int> empty = {};
assert(#empty == 0, "#empty should be 0");
assert(typeof(empty) == "table", "empty map should be 'table'");

map<any, any> e2 = {};
e2["key"] = 1;
assert(e2["key"] == 1, "e2['key'] should be 1");

print("empty_map tests passed!");
