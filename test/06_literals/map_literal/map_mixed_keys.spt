// 测试: Map - 混合键类型
// 语法: mapExpression, mapEntry
// 描述: 测试Map中使用不同类型的键

map<any, any> m = {};
m[1] = "int key";
m["str"] = "str key";
m[true] = "bool key";
m[3.14] = "float key";
m[-1] = "negative key";

assert(m[1] == "int key", "m[1] should be 'int key'");
assert(m["str"] == "str key", "m['str'] should be 'str key'");
assert(m[true] == "bool key", "m[true] should be 'bool key'");
assert(m[3.14] == "float key", "m[3.14] should be 'float key'");
assert(m[-1] == "negative key", "m[-1] should be 'negative key'");

print("map_mixed_keys tests passed!");
