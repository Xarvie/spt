// 测试: Map - 嵌套Map
// 语法: mapExpression
// 描述: 测试嵌套的Map结构

map<str, any> m = {
    "user1": {"name": "Alice", "age": "25"},
    "user2": {"name": "Bob", "age": "30"}
};

assert(m["user1"]["name"] == "Alice", "user1 name should be Alice");
assert(m["user1"]["age"] == "25", "user1 age should be 25");
assert(m["user2"]["name"] == "Bob", "user2 name should be Bob");

print("nested_map tests passed!");
