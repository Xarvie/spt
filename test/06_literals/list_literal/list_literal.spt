// 测试: 字面量 - List字面量
// 语法: listExpression -> OSB expressionList? CSB
// 描述: 测试List字面量

list<int> a = [1, 2, 3];
list<any> b = [1, "hello", true, null];
list<list<int>> c = [[1, 2], [3, 4]];
assert(#a == 3, "a should have length 3");
assert(a[0] == 1, "a[0] should be 1");
assert(b[1] == "hello", "b[1] should be 'hello'");
assert(c[0][0] == 1, "c[0][0] should be 1");

print("list_literal tests passed!");
