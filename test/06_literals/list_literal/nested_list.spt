// 测试: List - 嵌套List
// 语法: listExpression
// 描述: 测试嵌套的List结构

list<list<int>> matrix = [[1, 2], [3, 4], [5, 6]];
assert(#matrix == 3, "matrix should have 3 rows");
assert(#matrix[0] == 2, "first row should have 2 elements");
assert(matrix[0][0] == 1, "matrix[0][0] should be 1");
assert(matrix[0][1] == 2, "matrix[0][1] should be 2");
assert(matrix[1][0] == 3, "matrix[1][0] should be 3");
assert(matrix[2][1] == 6, "matrix[2][1] should be 6");

print("nested_list tests passed!");
