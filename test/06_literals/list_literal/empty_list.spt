// 测试: 字面量 - 空列表
// 语法: listExpression -> OSB expressionList? CSB
// 描述: 测试空列表字面量

list<int> empty = [];
assert(#empty == 0, "empty list should have length 0");
assert(typeof(empty) == "array", "empty list should be 'array'");

list<any> e2 = [];
table.push(e2, 1);
assert(#e2 == 1, "e2 should have length 1 after push");
assert(e2[0] == 1, "e2[0] should be 1");

print("empty_list tests passed!");
