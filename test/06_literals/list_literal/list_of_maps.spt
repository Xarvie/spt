// 测试: List和Map混合 - List包含Map
// 语法: listExpression, mapExpression
// 描述: 测试List中包含Map元素

list<any> users = [
    {"name": "Alice", "age": "25"},
    {"name": "Bob", "age": "30"},
    {"name": "Charlie", "age": "35"}
];

assert(users[0]["name"] == "Alice", "first user name should be Alice");
assert(users[1]["age"] == "30", "second user age should be 30");
assert(users[2]["name"] == "Charlie", "third user name should be Charlie");

print("list_of_maps tests passed!");
