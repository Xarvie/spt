// 测试: List - 作为函数参数和返回值
// 语法: listExpression, functionDeclaration
// 描述: 测试List作为函数参数和返回值

int sum(list arr) {
    int total = 0;
    for (i = 0, #arr - 1) {
        total += arr[i];
    }
    return total;
}

list<int> nums = [1, 2, 3, 4, 5];
assert(sum(nums) == 15, "sum should be 15");

list makeList() {
    return [100, 200, 300];
}

any result = makeList();
assert(result[0] == 100, "result[0] should be 100");
assert(result[2] == 300, "result[2] should be 300");
assert(#result == 3, "#result should be 3");

print("list_func_param_return tests passed!");
