// 测试: List - 引用行为
// 语法: listExpression
// 描述: 测试List的引用语义

list<int> a = [1, 2, 3];
list<int> b = a;
b[0] = 99;
assert(a[0] == 99, "a[0] should be 99 (reference)");
assert(b[0] == 99, "b[0] should be 99");

list<int> c = [1, 2, 3];
list<int> d = c;
table.push(d, 4);
assert(#c == 4, "#c should be 4 (shared reference)");
assert(#d == 4, "#d should be 4");

print("list_reference tests passed!");
