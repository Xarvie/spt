// 测试: 字面量 - 十六进制浮点数
// 语法: FLOAT_LITERAL -> '0' [xX] HEX_DIGIT+ '.' HEX_DIGIT* HEX_EXPONENT?
// 描述: 测试十六进制浮点数字面量

float a = 0x1.5p2;
float b = 0x1.fp3;
float c = 0x0.1p4;
assert(a == 5.25, "0x1.5p2 should be 5.25");
assert(b == 15.5, "0x1.fp3 should be 15.5");
assert(c == 1.0, "0x0.1p4 should be 1.0");

print("hex_float tests passed!");
