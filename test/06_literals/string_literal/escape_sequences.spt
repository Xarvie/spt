// 测试: 字面量 - 转义序列
// 语法: EscapeSequence
// 描述: 测试字符串中的所有转义序列

str f = "quote\"here";
str g = "apostrophe'here";
str h = "backslash\\here";
assert(#f == 10, "f length should be 10");
assert(#g == 15, "g length should be 15");
assert(#h == 14, "h length should be 14");

print("escape_sequences tests passed!");
