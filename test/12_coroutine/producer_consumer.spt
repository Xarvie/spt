// 测试: 协程 - 生产者消费者模式
// 语法: 协程协作
// 描述: 测试协程实现生产者消费者模式

int consumed = 0;

coro producer = coroutine.create(function() -> int {
    int i = 1;
    while (i <= 3) {
        coroutine.yield(i);
        i += 1;
    }
    return 0;
});

vars ok, val = coroutine.resume(producer);
assert(val == 1, "first should be 1");
vars ok2, val2 = coroutine.resume(producer);
assert(val2 == 2, "second should be 2");
vars ok3, val3 = coroutine.resume(producer);
assert(val3 == 3, "third should be 3");

print("producer_consumer tests passed!");
