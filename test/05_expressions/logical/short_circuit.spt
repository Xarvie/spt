// 测试: 基础语法 - 逻辑短路
// 语法: logicalOrExp, logicalAndExp
// 描述: 测试逻辑运算的短路求值

bool t = true;
bool f = false;
str result = "";
if (t || (1/0 == 0)) {
    result = "OR OK";
}
assert(result == "OR OK", "OR short-circuit should work");

if (f && (1/0 == 0)) {
    result = "Fail";
} else {
    result = "AND OK";
}
assert(result == "AND OK", "AND short-circuit should work");

print("short_circuit tests passed!");
