// 测试: 表达式 - 逻辑运算
// 语法: logicalOrExp, logicalAndExp
// 描述: 测试逻辑运算符

bool a = true && false;
bool b = true || false;
bool c = !false;
assert(a == false, "true && false should be false");
assert(b == true, "true || false should be true");
assert(c == true, "!false should be true");

print("logical_ops tests passed!");
