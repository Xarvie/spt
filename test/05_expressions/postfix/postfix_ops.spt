// 测试: 表达式 - 后缀表达式
// 语法: postfixSuffix -> OSB expression CSB | DOT IDENTIFIER | OP arguments? CP
// 描述: 测试后缀表达式（索引、成员访问、函数调用）

list<int> arr = [10, 20, 30];
assert(arr[0] == 10, "arr[0] should be 10");

map<str, int> m = {"x": 1, "y": 2};
assert(m["x"] == 1, "m['x'] should be 1");

class Point {
    int x;
    int y;
    void __init(int x, int y) {
        this.x = x;
        this.y = y;
    }
}

Point p = Point(3, 4);
assert(p.x == 3, "p.x should be 3");
assert(p.y == 4, "p.y should be 4");

print("postfix_ops tests passed!");
