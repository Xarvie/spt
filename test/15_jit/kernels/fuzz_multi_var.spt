// === multi_var_dep: 3-variable loop-carried dependency (tribonacci) ===
int a = 0; int b = 0; int c = 1;
for (int i = 0, 1000000) { int t = a + b + c; a = b; b = c; c = t; }
print(c);

// === swap_xor: XOR swap in loop ===
int x = 12345; int y = 67890;
for (int i = 0, 1000000) { x = x ^ y; y = x ^ y; x = x ^ y; }
print(x); print(y);

// === rotate3: 3-way rotation with temp ===
int p = 1; int q = 2; int r = 3;
for (int i = 0, 999999) { int t = p; p = q; q = r; r = t; }
print(p); print(q); print(r);

// === gcd_loop: subtractive GCD in a while loop ===
int g1 = 1000000007; int g2 = 999999937;
while (g1 != g2) { if (g1 > g2) { g1 = g1 - g2; } else { g2 = g2 - g1; } }
print(g1);

// === collatz: Collatz sequence length ===
int n = 123456789; int steps = 0;
while (n != 1) { if (n % 2 == 0) { n = n / 2; } else { n = 3 * n + 1; } steps = steps + 1; }
print(steps);

// === power_loop: integer power by repeated squaring in a loop ===
int base = 3; int exp = 1000000; int result = 1;
while (exp > 0) { if (exp % 2 == 1) { result = result * base; } base = base * base; exp = exp / 2; }
print(result % 1000003);

// === factorial_mod: factorial mod prime ===
int fm = 1;
for (int i = 1, 100000) { fm = (fm * i) % 1000000007; }
print(fm);

// === sum_squares: sum of squares with accumulator ===
int sq = 0;
for (int i = 0, 1000000) { sq = sq + i * i; }
print(sq);

// === alternating_sum: alternating sign sum ===
int alt = 0;
for (int i = 0, 1000000) { if (i % 2 == 0) { alt = alt + i; } else { alt = alt - i; } }
print(alt);

// === double_accum: two independent accumulators ===
int s1 = 0; int s2 = 0;
for (int i = 0, 1000000) { s1 = s1 + i; s2 = s2 + i * 2; }
print(s1 % 1000003); print(s2 % 1000003);
