// 测试: 边界情况 - 深层嵌套调用
// 语法: postfixCallSuffix
// 描述: 测试深层嵌套的函数调用

int f1(int x) { return x + 1; }
int f2(int x) { return f1(x) * 2; }
int f3(int x) { return f2(x) + 3; }
int f4(int x) { return f3(x) * 4; }
int f5(int x) { return f4(x) + 5; }

assert(f5(0) == 25, "f5(0) should be 25");

print("deeply_nested_call tests passed!");
