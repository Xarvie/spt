// 测试: 内置函数 - string.format
// 语法: string.format(format, ...)
// 描述: 测试string.format格式化字符串

assert(string.format("Hello %s", "World") == "Hello World", "format string should work");
assert(string.format("Number: %d", 42) == "Number: 42", "format int should work");

print("string_format tests passed!");
