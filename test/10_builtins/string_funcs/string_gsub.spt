// 测试: 内置函数 - string.gsub
// 语法: string.gsub(s, pattern, repl)
// 描述: 测试字符串替换

str s = "Hello World";
vars result, count = string.gsub(s, "o", "0");
assert(count == 2, "count should be 2");

vars result2, count2 = string.gsub("aaa", "a", "b");
assert(count2 == 3, "count2 should be 3");

print("string_gsub tests passed!");
