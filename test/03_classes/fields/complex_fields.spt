// 测试: 类 - 复杂字段
// 语法: classFieldMember
// 描述: 测试类中包含复杂类型的字段

class Container {
    any data;
    void __init(any d) {
        this.data = d;
    }
}

Container c1 = Container(42);
Container c2 = Container("hello");
Container c3 = Container([1, 2, 3]);

assert(c1.data == 42, "c1.data should be 42");
assert(c2.data == "hello", "c2.data should be 'hello'");
assert(c3.data[1] == 2, "c3.data[1] should be 2");

print("complex_fields tests passed!");
