// 测试: 类 - 带初始化的字段
// 语法: classFieldMember -> declaration_item (ASSIGN expression)?
// 描述: 测试类字段带初始化表达式

class Config {
    int timeout = 30;
    str host = "localhost";
    bool debug = true;
}

Config c = new Config();
assert(c.timeout == 30, "c.timeout should be 30");
assert(c.host == "localhost", "c.host should be 'localhost'");
assert(c.debug == true, "c.debug should be true");

print("field_with_init tests passed!");
