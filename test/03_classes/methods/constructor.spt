// 测试: 类 - 构造函数__init
// 语法: classMethodMember
// 描述: 测试类构造函数__init

class Point {
    int x;
    int y;
    void __init(int x, int y) {
        this.x = x;
        this.y = y;
    }
}

Point p = Point(10, 20);
assert(p.x == 10, "p.x should be 10");
assert(p.y == 20, "p.y should be 20");

print("constructor tests passed!");
