// 测试: 类 - 运算符重载__unm
// 语法: classMethodMember, operator overloading
// 描述: 测试类运算符重载__unm（一元负号）

class Number {
    int value;
    void __init(int v) {
        this.value = v;
    }
    Number __unm() {
        return Number(-this.value);
    }
}

Number a = Number(5);
Number b = -a;
assert(b.value == -5, "b.value should be -5");

print("operator_overload_unm tests passed!");
