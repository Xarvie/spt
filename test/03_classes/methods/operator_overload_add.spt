// 测试: 类 - 运算符重载__add
// 语法: classMethodMember, operator overloading
// 描述: 测试类运算符重载__add

class Vec2 {
    int x;
    int y;
    void __init(int x, int y) {
        this.x = x;
        this.y = y;
    }
    Vec2 __add(Vec2 other) {
        return new Vec2(this.x + other.x, this.y + other.y);
    }
}

Vec2 a = new Vec2(1, 2);
Vec2 b = new Vec2(3, 4);
Vec2 c = a + b;
assert(c.x == 4, "c.x should be 4");
assert(c.y == 6, "c.y should be 6");

print("operator_overload_add tests passed!");
