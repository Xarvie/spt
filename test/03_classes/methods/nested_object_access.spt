// 测试: 类 - 嵌套对象访问
// 语法: postfixExpression
// 描述: 测试嵌套对象的成员访问

class Inner {
    int value;
    void __init(int v) {
        this.value = v;
    }
}

class Outer {
    Inner inner;
    void __init(int v) {
        this.inner = Inner(v);
    }
}

Outer o = Outer(42);
assert(o.inner.value == 42, "o.inner.value should be 42");

print("nested_object_access tests passed!");
