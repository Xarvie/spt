// 测试: 类 - 多实例
// 语法: classDeclaration, newExp
// 描述: 测试创建多个类实例

class Box {
    int value;
    void __init(int v) {
        this.value = v;
    }
}

Box a = Box(10);
Box b = Box(20);
Box c = Box(30);

assert(a.value == 10, "a.value should be 10");
assert(b.value == 20, "b.value should be 20");
assert(c.value == 30, "c.value should be 30");

a.value = 100;
assert(a.value == 100, "a.value should be 100 after update");
assert(b.value == 20, "b.value should still be 20");

print("multiple_instances tests passed!");
