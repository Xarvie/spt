// 测试: 类 - const字段
// 语法: classFieldMember -> CONST? declaration_item
// 描述: 测试类中的const字段

class Constants {
    const int MAX = 100;
    const str NAME = "test";
}

Constants c = new Constants();
assert(c.MAX == 100, "c.MAX should be 100");
assert(c.NAME == "test", "c.NAME should be 'test'");

print("const_field tests passed!");
