// 测试: Lambda - lambda作为参数
// 语法: lambdaExpression
// 描述: 测试lambda作为函数参数（高阶函数）

int apply(function f, int x) {
    return f(x);
}

auto double = function(int n) -> int { return n * 2; };
auto square = function(int n) -> int { return n * n; };

assert(apply(double, 5) == 10, "double(5) should be 10");
assert(apply(square, 5) == 25, "square(5) should be 25");

print("lambda_higher_order tests passed!");
