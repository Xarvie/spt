// 测试: Lambda - 可变参数
// 语法: parameterList -> parameter (COMMA parameter)* (COMMA DDD)? | DDD
// 描述: 测试lambda中的可变参数

auto sum = function(...) -> int {
    auto args = table.pack(...);
    int total = 0;
    for (i = 0, #args - 1) {
        total += args[i];
    }
    return total;
};

assert(sum(1, 2, 3) == 6, "sum(1,2,3) should be 6");
assert(sum(10, 20, 30, 40) == 100, "sum(10,20,30,40) should be 100");

print("lambda_variadic tests passed!");
