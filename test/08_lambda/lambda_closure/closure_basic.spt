// 测试: Lambda - 闭包
// 语法: lambdaExpression
// 描述: 测试lambda闭包捕获外部变量

auto makeCounter = function() -> function {
    int count = 0;
    return function() -> int {
        count = count + 1;
        return count;
    };
};

auto c1 = makeCounter();
assert(c1() == 1, "first call should return 1");
assert(c1() == 2, "second call should return 2");
assert(c1() == 3, "third call should return 3");

print("closure_basic tests passed!");
