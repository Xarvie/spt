// 测试: 声明 - vars多变量声明
// 语法: VARS IDENTIFIER (COMMA IDENTIFIER)* (ASSIGN expression)?
// 描述: 测试vars关键字声明多个变量

vars a, b;
a = 1;
b = 2;
assert(a == 1, "a should be 1");
assert(b == 2, "b should be 2");

vars x, y, z;
x = 10;
y = 20;
z = 30;
assert(x == 10, "x should be 10");
assert(y == 20, "y should be 20");
assert(z == 30, "z should be 30");

print("vars_multi_decl tests passed!");
