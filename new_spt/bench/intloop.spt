/* Tight typed-integer arithmetic loop (IMUL/IADD/ISUB/IMOD + compare/branch).
 * Per-iteration delta is bounded so the accumulator never overflows 64-bit,
 * keeping the result identical across SPT and Lua. */
function bench(int n) {
  int s = 0;
  int i = 0;
  while (i < n) {
    s = s + (i * 7 + 13) % 101 - 50;
    i = i + 1;
  }
  return s;
}
