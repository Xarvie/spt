// 验证 B4: 协程 yield 返回值错位
str received = "NOT_SET";
coro co = coroutine.create(fn() -> void {
    vars y = coroutine.yield("first");
    received = tostring(y);
});
vars ok1, v1 = coroutine.resume(co);
print("B4 first yield returned: " .. tostring(v1));
vars ok2, v2 = coroutine.resume(co, "world");
print("B4 yield received: " .. received);
print("B4 expected: world");
if (received == "world") {
    print("B4: PASS - yield return correct");
} else {
    print("B4: BUG CONFIRMED - yield received " .. received .. " instead of world");
}
