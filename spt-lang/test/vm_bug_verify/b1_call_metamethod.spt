// 验证 B1: __call 元方法参数错位
class Callable {
    void __init() {}
    int __call(int a, int b) {
        return a + b;
    }
}
Callable c = Callable();
int result = c(10, 20);
print("B1 __call result: " .. tostring(result));
print("B1 expected: 30 (10+20)");
if (result == 30) {
    print("B1: PASS - __call params correct");
} else {
    print("B1: BUG CONFIRMED - __call params misaligned, got " .. tostring(result));
}
