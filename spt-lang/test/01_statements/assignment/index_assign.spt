// 测试: 语句 - 索引赋值
// 语法: lvalue -> (IDENTIFIER) ( lvalueSuffix )* #lvalueBase
// 描述: 测试数组索引作为左值的赋值

list<int> arr = [1, 2, 3];
arr[0] = 100;
assert(arr[0] == 100, "arr[0] should be 100");
assert(arr[1] == 2, "arr[1] should be 2");
assert(arr[2] == 3, "arr[2] should be 3");

print("index_assign tests passed!");
