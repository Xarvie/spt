// 测试: 控制流 - while中的continue
// 语法: whileStatement, CONTINUE
// 描述: 测试while循环中的continue语句

int i = 0;
int sum = 0;
while (i < 5) {
    i += 1;
    if (i == 3) {
        continue;
    }
    sum += i;
}
// sum = 1 + 2 + 4 + 5 = 12 (skips 3)
assert(sum == 12, "sum should be 12 (1+2+4+5, skipping 3)");

print("continue_in_while tests passed!");
