// 测试: 控制流 - 多路径return
// 语法: RETURN expression? SEMICOLON
// 描述: 测试函数中多个return路径

int test(int x) {
    if (x < 0) {
        return -1;
    }
    if (x == 0) {
        return 0;
    }
    return 1;
}

assert(test(-5) == -1, "test(-5) should be -1");
assert(test(0) == 0, "test(0) should be 0");
assert(test(10) == 1, "test(10) should be 1");

print("return_multi_path tests passed!");
