// 测试: utf8库函数
// 语法: utf8模块函数
// 描述: 测试utf8模块的常用函数

// 测试 utf8.len
assert(utf8.len("hello") == 5, "utf8.len('hello') should be 5");
assert(utf8.len("你好世界") == 4, "utf8.len('你好世界') should be 4");
assert(utf8.len("") == 0, "utf8.len('') should be 0");

// 测试 utf8.codepoint
assert(utf8.codepoint("A", 0, 1) == 65, "utf8.codepoint('A', 0, 1) should be 65");
assert(utf8.codepoint("ABC", 0, 1) == 65, "utf8.codepoint('ABC', 0, 1) should be 65");
assert(utf8.codepoint("ABC", 1, 2) == 66, "utf8.codepoint('ABC', 1, 2) should be 66");

// 测试 utf8.char
assert(utf8.char(65) == "A", "utf8.char(65) should be 'A'");
assert(utf8.char(20013) == "中", "utf8.char(20013) should be '中'");

// 测试 utf8.offset
assert(utf8.offset("hello", 1, 0) == 1, "utf8.offset('hello', 1, 0) should be 1");
assert(utf8.offset("hello", 2, 0) == 2, "utf8.offset('hello', 2, 0) should be 2");

print("utf8 library tests passed!");
