// 测试: debug 库 upvalue/local 函数的 slot-2 ABI + 0-based 索引
// 语法: debug.getupvalue / setupvalue / upvalueid / upvaluejoin / getlocal / setlocal
// 描述: 验证 receiver 占 arg1，closure 从 arg2 起；upvalue/local 索引 0-based（0 = 第一个）

// ===== upvalue 测试 =====

fn make() {
    int x = 42;
    return fn() -> int { return x; };
}

fn getter = make();
assert(getter() == 42, "closure initial upvalue");

// debug.getupvalue(f, n) —— n 0-based，0 = 第一个 upvalue
vars name0, val0 = debug.getupvalue(getter, 0);
assert(name0 == "x", "getupvalue(f, 0) name should be 'x'");
assert(val0 == 42, "getupvalue(f, 0) value should be 42");

// 越界 upvalue 索引返回无值（-1 = 越界，对应 C API 的 0）
vars nameN, valN = debug.getupvalue(getter, -1);
assert(nameN == null, "getupvalue(f, -1) out of range returns null");

// 正向越界
vars nameBig, valBig = debug.getupvalue(getter, 5);
assert(nameBig == null, "getupvalue(f, 5) out of range returns null");

// debug.setupvalue(f, n, value) —— value 在 arg4，n 0-based
debug.setupvalue(getter, 0, 999);
assert(getter() == 999, "closure upvalue changed via setupvalue");

vars name1, val1 = debug.getupvalue(getter, 0);
assert(val1 == 999, "getupvalue after setupvalue should be 999");

// debug.upvalueid(f, n) —— 返回 light userdata
auto id1 = debug.upvalueid(getter, 0);
assert(id1 != null, "upvalueid should be non-null");
assert(typeof(id1) == "userdata", "upvalueid should be userdata");

// debug.upvaluejoin(f1, n1, f2, n2) —— 共享 upvalue，n 0-based
fn g1 = make();
fn g2 = make();
assert(g1() == 42, "g1 initial");
assert(g2() == 42, "g2 initial");

debug.upvaluejoin(g1, 0, g2, 0);
debug.setupvalue(g2, 0, 777);
assert(g1() == 777, "g1 should see g2's upvalue after upvaluejoin");
assert(g2() == 777, "g2 should also see the same upvalue");

// ===== getlocal/setlocal 测试（0-based nvar）=====
// SPT level 语义沿用 Lua：level 0 = db_getlocal C 帧，level 1 = 调用者（用户函数）。
// SPT 函数隐式 receiver 槽作为 nvar 0（名为 "(receiver)"），用户局部变量从 nvar 1 起。
// 这是 debug 库的透明低层语义，与 Lua 暴露 "(C temporary)" 同理。

// getlocal(level, nvar)：列 probe 帧的局部变量
str probe() {
    int aa = 11;
    int bb = 22;
    // level 1 = probe 自己；nvar 0 = receiver，nvar 1 = aa
    vars nm, vv = debug.getlocal(1, 0);
    if (nm == "(receiver)") {
        vars nm2, vv2 = debug.getlocal(1, 1);
        return nm2;
    }
    return nm;
}
assert(probe() == "aa", "getlocal(1, 1) should return first user local 'aa'");

// setlocal(level, nvar, value)：改 probe 的 aa
int mutator() {
    int target = 100;
    // nvar 0 = receiver, nvar 1 = target
    debug.setlocal(1, 1, 888);
    return target;
}
assert(mutator() == 888, "setlocal(1, 1, 888) should change target");

// 越界 nvar 返回 null
str probeOOB() {
    int only = 1;
    vars nm, vv = debug.getlocal(1, 99);
    return nm;
}
assert(probeOOB() == null, "getlocal(1, 99) out of range returns null");

print("debug_upvalue_local tests passed!");
