// 测试: 错误路径 - pcall 恢复后状态一致性
// 描述: 验证 pcall 捕获错误后，VM 状态保持一致，后续操作正常工作

// ---- 外层变量在错误后保持不变 ----
vars outer = 100;
vars ok1, err1 = pcall(fn() -> int { outer = 999; error("boom"); return 1; });
assert(ok1 == false, "should fail");
// 注意：错误前对 outer 的赋值已经生效（SPT 语义），这里验证 outer 不被错误破坏
assert(outer == 999, "outer should keep value set before error");

// ---- 错误后能继续调用普通函数 ----
int add(int a, int b) { return a + b; }
vars ok2, err2 = pcall(fn() -> int { error("fail"); return 0; });
assert(ok2 == false, "pcall should fail");
vars sum = add(3, 4);
assert(sum == 7, "function call after error should work");

// ---- 连续多次 pcall ----
int total = 0;
for (int i = 0, 4) {
    vars ok, r = pcall(fn() -> int {
        if (i == 2) { error("skip 2"); }
        return i * 10;
    });
    if (ok) { total = total + r; }
}
assert(total == 80, "total should be 0+10+30+40 = 80");

// ---- 嵌套 pcall 恢复 ----
vars ok3, err3 = pcall(fn() -> int {
    vars ok_inner, err_inner = pcall(fn() -> int {
        error("inner error");
        return 1;
    });
    assert(ok_inner == false, "inner should fail");
    vars inner_pos, _ = string.find(err_inner, "inner error");
    assert(inner_pos != null, "inner error message should contain 'inner error'");
    error("outer error");
    return 2;
});
assert(ok3 == false, "outer should fail");
vars outer_pos, _ = string.find(err3, "outer error");
assert(outer_pos != null, "outer error message should contain 'outer error'");

// ---- 闭包捕获在错误后仍正常 ----
fn make_counter() {
    vars count = 0;
    return fn() -> int { count = count + 1; return count; };
}
vars counter = make_counter();
vars ok4, err4 = pcall(fn() -> int { error("closure test"); return 0; });
assert(ok4 == false, "should fail");
assert(counter() == 1, "closure call 1");
assert(counter() == 2, "closure call 2");

// ---- 错误后 list 操作正常 ----
list<int> lst = [1, 2, 3];
vars ok5, err5 = pcall(fn() -> int { error("list test"); return 0; });
assert(ok5 == false, "should fail");
table.push(lst, 4);
assert(#lst == 4, "list should have 4 elements");
assert(lst[3] == 4, "last element should be 4");

// ---- 错误后 map 操作正常 ----
map<str, int> m = {"a": 1, "b": 2};
vars ok6, err6 = pcall(fn() -> int { error("map test"); return 0; });
assert(ok6 == false, "should fail");
m["c"] = 3;
assert(m["a"] == 1, "map a should be 1");
assert(m["c"] == 3, "map c should be 3");

// ---- 错误在循环中不破坏循环 ----
list<int> collected = [];
for (int i = 0, 4) {
    vars ok, r = pcall(fn() -> int {
        if (i % 2 == 0) { error("even"); }
        return i;
    });
    if (ok) { table.push(collected, r); }
}
assert(#collected == 2, "should collect 2 odd values");
assert(collected[0] == 1, "first odd is 1");
assert(collected[1] == 3, "second odd is 3");

// ---- pcall 成功后返回值正确传递 ----
vars ok7, r7 = pcall(fn() -> int { return 10; });
assert(ok7 == true, "should succeed");
assert(r7 == 10, "return value");

// ---- 错误后全局函数仍可调用 ----
str greet(str name) { return "hello " .. name; }
vars ok8, err8 = pcall(fn() -> int { error("global test"); return 0; });
assert(ok8 == false, "should fail");
assert(greet("world") == "hello world", "global function should work");

// ---- 错误对象类型保留 ----
vars ok9, err9 = pcall(fn() -> int { error(42); return 0; });
assert(ok9 == false, "should fail");
assert(typeof(err9) == "int", "error object should preserve int type");
assert(err9 == 42, "error object value should be 42");

vars ok10, err10 = pcall(fn() -> int { error({"code": 500}); return 0; });
assert(ok10 == false, "should fail");
assert(typeof(err10) == "map", "error object should preserve map type");
assert(err10["code"] == 500, "error table code should be 500");

// ---- pcall 捕获后能立即再次 pcall 同一函数 ----
int flaky_calls = 0;
vars flaky = fn() -> int {
    flaky_calls = flaky_calls + 1;
    if (flaky_calls < 3) { error("not ready"); }
    return flaky_calls;
};
vars r1_ok, r1 = pcall(flaky);
vars r2_ok, r2 = pcall(flaky);
vars r3_ok, r3 = pcall(flaky);
assert(r1_ok == false, "first call should fail");
assert(r2_ok == false, "second call should fail");
assert(r3_ok == true, "third call should succeed");
assert(r3 == 3, "third call should return 3");

print("pcall_recovery tests passed!");
