// 测试: 内置函数 - string模块函数
// 语法: string模块函数
// 描述: 测试string模块的各种函数

str s = "Hello World";
assert(string.len(s) == 11, "len should be 11");
assert(string.sub(s, 0, 5) == "Hello", "sub(0,5) should be 'Hello'");
assert(string.upper(s) == "HELLO WORLD", "upper should work");
assert(string.lower(s) == "hello world", "lower should work");
assert(string.rep("ab", 3) == "ababab", "rep should work");
assert(string.reverse("abc") == "cba", "reverse should work");

print("string_funcs tests passed!");
