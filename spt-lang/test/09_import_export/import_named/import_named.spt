// 测试: 导入 - 命名成员导入
// 语法: importStatement -> IMPORT OCB importSpecifier (COMMA importSpecifier)* CCB FROM STRING_LITERAL #importNamedStmt
// 描述: 测试import { a, b }语法

import { abs, max } from "math";
assert(abs(-10) == 10, "abs(-10) should be 10");
assert(max(15, 25) == 25, "max(15, 25) should be 25");

print("import_named tests passed!");
