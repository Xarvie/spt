// 测试: 函数 - 嵌套函数
// 语法: functionDeclaration
// 描述: 测试函数内部声明函数

int outer(int x) {
    int inner(int y) {
        return y * 2;
    }
    return inner(x) + 1;
}

assert(outer(5) == 11, "outer(5) should be 11");
assert(outer(10) == 21, "outer(10) should be 21");

print("nested_function tests passed!");
