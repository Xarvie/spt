// 测试: 内置函数 - list模块
// 语法: list.push, list.pop, list.insert, list.remove, list.concat, list.sort
// 描述: 测试list模块函数

list<int> l = [1, 2, 3];
list.push(l, 4);
assert(#l == 4, "list length should be 4 after push");
assert(l[3] == 4, "last element should be 4");

list.insert(l, 1, 99);
assert(l[1] == 99, "element at index 1 should be 99");

any val = list.remove(l, 0);
assert(val == 1, "removed value should be 1");
assert(#l == 4, "list length should be 4 after remove");

print("builtin_list tests passed!");
