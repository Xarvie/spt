// 测试: 声明 - 多返回值函数
// 语法: GLOBAL? CONST? VARS qualifiedIdentifier OP parameterList? CP blockStatement #multiReturnFunctionDeclarationDef
// 描述: 测试多返回值函数声明

vars returnAB(int a, int b) {
    return a, b;
}

vars x, y = returnAB(1, 2);
assert(x == 1, "x should be 1");
assert(y == 2, "y should be 2");

print("multi_return_basic tests passed!");
