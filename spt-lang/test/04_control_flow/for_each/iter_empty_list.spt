// 测试: iter() 自动包 - 空集合
// 空列表和空 map 应立即终止迭代（0 次）

list<int> l = [];
int count = 0;
for (auto v : l) { count += 1; }
assert(count == 0, "empty list 0 iterations");

map<int, int> m = {};
int mcount = 0;
for (auto v : m) { mcount += 1; }
assert(mcount == 0, "empty map 0 iterations");

// 2 变量空集合
list<int> l2 = [];
int kcount = 0;
for (auto i, v : l2) { kcount += 1; }
assert(kcount == 0, "empty list 2var 0 iterations");

print("iter_empty_list passed!");
