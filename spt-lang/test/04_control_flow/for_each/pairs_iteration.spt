// 测试: 迭代 - pairs遍历
// 语法: forEachControl -> forEachVar (COMMA forEachVar)* COL expressionList
// 描述: 测试pairs迭代器遍历List和Map

int listCount = 0;
list<any> l = [10, null, 30];
for (k, v : pairs(l)) {
    listCount += 1;
}
assert(listCount == 3, "should iterate 3 items in list");

int mapCount = 0;
map<int, int> m = {1:30, 3:30};
for (k, v : pairs(m)) {
    mapCount += 1;
}
assert(mapCount == 2, "should iterate 2 items in map");

print("pairs_iteration tests passed!");
