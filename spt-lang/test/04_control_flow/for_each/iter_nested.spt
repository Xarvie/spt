// 测试: iter() 自动包 - 嵌套 for-each
// 验证多层 for-each 自动包正确工作（隐藏变量不冲突）

list<int> a = [1, 2];
list<int> b = [10, 20];
int sum = 0;
for (auto x : a) {
    for (auto y : b) { sum += x * y; }
}
// 1*10 + 1*20 + 2*10 + 2*20 = 10+20+20+40 = 90
assert(sum == 90, "nested list x list");

// list × map
list<int> li = [1, 2];
map<int, int> mi = {10: 100, 20: 200};
int msum = 0;
for (auto x : li) {
    for (auto v : mi) { msum += x * v; }
}
// 1*100 + 1*200 + 2*100 + 2*200 = 100+200+200+400 = 900
assert(msum == 900, "nested list x map");

// 3 层嵌套
list<int> c = [1];
int triple = 0;
for (auto x : a) {
    for (auto y : b) {
        for (auto z : c) { triple += x * y * z; }
    }
}
// (1*10*1) + (1*20*1) + (2*10*1) + (2*20*1) = 10+20+20+40 = 90
assert(triple == 90, "triple nested");

print("iter_nested passed!");
