// 测试: 控制流 - if 无花括号单语句体
// 语法: ifStatement -> IF OP expression CP statement
// 描述: 测试 if/else if/else 不使用花括号的单语句写法

int x = 5;
str result = "";

if (x > 10) result = "big";
else if (x == 5) result = "five";
else result = "other";

assert(result == "five", "result should be 'five'");

// 无 else 的单语句 if
if (x == 5) result = "yes";
assert(result == "yes", "result should be 'yes'");

// 嵌套无花括号 if
int a = 1;
int b = 2;
str r2 = "";
if (a == 1)
    if (b == 2) r2 = "nested";
assert(r2 == "nested", "nested if without braces");

print("if_no_brace tests passed!");
