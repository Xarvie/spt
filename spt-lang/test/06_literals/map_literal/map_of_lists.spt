// 测试: List和Map混合 - Map包含List
// 语法: mapExpression, listExpression
// 描述: 测试Map中包含List值

map<str, any> data = {
    "numbers": [1, 2, 3],
    "strings": ["a", "b", "c"]
};

assert(data["numbers"][0] == 1, "data['numbers'][0] should be 1");
assert(data["numbers"][2] == 3, "data['numbers'][2] should be 3");
assert(data["strings"][1] == "b", "data['strings'][1] should be 'b'");

print("map_of_lists tests passed!");
