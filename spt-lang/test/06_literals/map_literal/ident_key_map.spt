// 测试: 字面量 - Map标识符键
// 语法: mapEntry -> IDENTIFIER COL expression #mapEntryIdentKey
// 描述: 测试Map使用标识符作为键

map<str, int> m = {
    x: 1,
    y: 2,
    z: 3
};

assert(m["x"] == 1, "m['x'] should be 1");
assert(m["y"] == 2, "m['y'] should be 2");
assert(m["z"] == 3, "m['z'] should be 3");

print("ident_key_map tests passed!");
