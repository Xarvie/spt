// 测试: Lambda - 嵌套闭包
// 语法: lambdaExpression
// 描述: 测试多层嵌套的闭包

auto outer = fn() -> fn {
    int a = 1;
    return fn() -> fn {
        int b = 2;
        return fn() -> int {
            return a + b;
        };
    };
};

auto f1 = outer();
auto f2 = f1();
assert(f2() == 3, "nested closure should return 3 (1+2)");

print("nested_closure tests passed!");
