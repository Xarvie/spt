// 测试: Lambda - 带参数lambda
// 语法: lambdaExpression -> FUNCTION OP parameterList? CP ARROW type blockStatement
// 描述: 测试带参数的lambda表达式

auto add = function(int a, int b) -> int {
    return a + b;
};
assert(add(3, 4) == 7, "add(3, 4) should be 7");

auto mul = function(int x, int y) -> int { return x * y; };
assert(mul(5, 6) == 30, "mul(5, 6) should be 30");

print("lambda_params tests passed!");
