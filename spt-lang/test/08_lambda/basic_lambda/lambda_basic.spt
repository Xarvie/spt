// 测试: Lambda - 基本lambda
// 语法: lambdaExpression -> FN OP parameterList? CP ARROW (type | VARS) blockStatement
// 描述: 测试基本lambda表达式

auto f1 = fn() -> int { return 1; };
auto f2 = fn() -> str { return "hi"; };
auto f3 = fn() -> void { };
assert(f1() == 1, "f1() should be 1");
assert(f2() == "hi", "f2() should be 'hi'");

print("lambda_basic tests passed!");
