// 测试: 类 - 静态成员
// 语法: classFieldMember -> STATIC? CONST? declaration_item, classMethodMember -> STATIC? CONST? type IDENTIFIER...
// 描述: 测试类的静态字段和方法

class Counter {
    static int count = 0;
    static int getCount() {
        return Counter.count;
    }
}

Counter.count = 5;
assert(Counter.count == 5, "Counter.count should be 5");
assert(Counter.getCount() == 5, "Counter.getCount() should be 5");

print("static_field_method tests passed!");
