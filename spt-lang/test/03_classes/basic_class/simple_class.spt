// 测试: 类 - 基本类定义
// 语法: classDeclaration -> CLASS IDENTIFIER OCB classMember* CCB #classDeclarationDef
// 描述: 测试基本类定义

class Point {
    int x;
    int y;
    void __init(int x, int y) {
        this.x = x;
        this.y = y;
    }
}

Point p = Point(10, 20);
assert(p.x == 10, "p.x should be 10");
assert(p.y == 20, "p.y should be 20");

print("simple_class tests passed!");
