// JIT kernel: chained container access through a Map (GETFIELD -> GETI/GETFIELD).
//
// Reading `m["k"][j]` or `m["k1"]["k2"]` chains a map field read into a further
// index/field read. The element-type predictor (rec_eval_container) follows the
// IR -- SLOAD -> GETFIELD -> GETI/GETFIELD -- to the record-time inner container,
// because the intermediate List/Map is produced earlier in the same trace and
// its live stack slot is stale by the back-edge (the §10.42 stale-live-read
// hazard). The base map of a chained GETFIELD is likewise resolved through the
// IR. All loads stay bounds- and type-guarded at run time, so the prediction is
// never load-bearing. List-of-list (a[i][j], pure chained GETI) already worked;
// this adds the map-rooted cases. No C call, no GC. Mixes an int list field, a
// float list field, and a nested map field.
map<string,list<int>> mi = {};
map<string,list<float>> mf = {};
map<string,map<string,int>> mm = {};
map<string,int> inner = {};
mi["a"] = [3, 1, 4, 1, 5, 9];
mf["v"] = [1.5, 2.5, 3.0, 0.5];
inner["x"] = 7;
inner["y"] = 11;
mm["p"] = inner;
int si = 0;
float sf = 0.0;
int sm = 0;
for (int rep = 0, 50000) {
  for (int j = 0, 5) { si = si + mi["a"][j]; }
  for (int j = 0, 3) { sf = sf + mf["v"][j]; }
  for (int j = 0, 9) { sm = sm + mm["p"]["x"] - mm["p"]["y"]; }
}
print(si);
print(sf);
print(sm);
