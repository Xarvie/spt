// === inline_simple: inline a simple leaf function ===
int sq(int x) { return x * x; }
int s = 0;
for (int i = 0, 1000000) { s = s + sq(i); }
print(s % 1000003);

// === inline_two_arg: inline function with two args ===
int addmul(int a, int b) { return a * 3 + b * 2; }
int s2 = 0;
for (int i = 0, 1000000) { s2 = s2 + addmul(i, i + 1); }
print(s2 % 1000003);

// === inline_chain: two inlineable functions in same loop ===
int dbl(int x) { return x + x; }
int inc(int x) { return x + 1; }
int s3 = 0;
for (int i = 0, 1000000) { s3 = s3 + dbl(inc(i)); }
print(s3 % 1000003);

// === inline_const_arg: inline with constant argument ===
int poly(int x) { return x * x + 3 * x + 2; }
int s4 = 0;
for (int i = 0, 1000000) { s4 = s4 + poly(5); }
print(s4 % 1000003);

// === inline_float: inline function returning float ===
float fhalf(int x) { return x / 2.0; }
float fs = 0.0;
for (int i = 0, 1000000) { fs = fs + fhalf(i); }
print(fs);

// === inline_branch: inline function with a branch ===
int absval(int x) { if (x < 0) { return -x; } return x; }
int s5 = 0;
for (int i = 0, 1000000) { s5 = s5 + absval(i - 500000); }
print(s5 % 1000003);

// === inline_multi_return: inline with multiple return paths ===
int classify(int x) { if (x < 100) { return 0; } if (x < 200) { return 1; } return 2; }
int c0 = 0; int c1 = 0; int c2 = 0;
for (int i = 0, 300) { int c = classify(i); if (c == 0) { c0 = c0 + 1; } else if (c == 1) { c1 = c1 + 1; } else { c2 = c2 + 1; } }
for (int rep = 0, 9999) { c0 = 0; c1 = 0; c2 = 0; for (int i = 0, 300) { int c = classify(i); if (c == 0) { c0 = c0 + 1; } else if (c == 1) { c1 = c1 + 1; } else { c2 = c2 + 1; } } }
print(c0); print(c1); print(c2);
