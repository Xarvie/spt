// 测试导入多个导出项
import * as m from "export_multiple";

assert(m.PI > 3.14, "m.PI should be > 3.14");
assert(m.E > 2.71, "m.E should be > 2.71");
assert(m.add(10, 20) == 30, "m.add(10, 20) should be 30");
assert(m.multiply(5, 6) == 30, "m.multiply(5, 6) should be 30");

print("test_import_multiple tests passed!");
