/* utils.spt — 工具模块（被多处 import）
**
** 测试要点：
**   P3:  definition/hover/references 跳转到此文件
**   P3:  rename calculate → compute 验证跨文件重命名
**   P5:  增量失效 — 添加 newFunc 后其他文件应能补全
**   P5:  workspace/symbol 搜索 calculate 应命中
*/

export int calculate(int a, int b) {
  return a + b;
}

export int formatTime(int seconds) {
  int hours = seconds / 3600;
  int mins = (seconds / 60) % 60;
  int secs = seconds % 60;
  return hours * 10000 + mins * 100 + secs;
}

export str greet(str name) {
  return "Hello, " .. name .. "!";
}

export int max(int a, int b) {
  if (a > b) {
    return a;
  }
  return b;
}

export int min(int a, int b) {
  if (a < b) {
    return a;
  }
  return b;
}
