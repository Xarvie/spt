/* codeaction_demo.spt — codeAction 测试（P4c）
**
** 测试要点：
**   P4c: 光标放在未 export 的函数/变量/类上
**   Ctrl+. (Quick Fix) 应出现 "Add 'export' modifier" 选项
**   选中后应在声明前插入 "export " 关键字
*/

int add(int a, int b) {
  return a + b;
}

int subtract(int a, int b) {
  return a - b;
}

int MULTIPLIER = 10;

class Calculator {
  int value;

  void __init(int v) {
    this.value = v;
  }

  int multiply(int x) {
    return this.value * x;
  }
}

str VERSION = "1.0.0";
