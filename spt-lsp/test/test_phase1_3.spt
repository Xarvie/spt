// Phase 1.3 控制流语句测试

// 测试1: if/else 语句
// 预期: 正确解析，无诊断错误
int cond = 1;
if (cond) {
    int a = 1;
} else {
    int b = 2;
}

// 测试2: if/else if/else 链
// 预期: 正确解析
if (cond == 1) {
    int x1 = 1;
} else if (cond == 2) {
    int x2 = 2;
} else {
    int x3 = 3;
}

// 测试3: while 语句
// 预期: 正确解析，变量i正确识别
int i = 0;
while (i < 10) {
    i = i + 1;
}

// 测试4: 数值 for 循环
// 预期: 变量j正确识别，可跳转
for (int j = 0, 10) {
    int temp = j;
}

// 测试5: 数值 for 带步长
// 预期: 变量k正确识别
for (int k = 0, 10, 2) {
    int temp = k;
}

// 测试6: auto 类型 for 循环变量
// 预期: 变量m正确识别
for (auto m = 0, 5) {
    int temp = m;
}

// 测试7: 无类型 for 循环变量
// 预期: 变量n正确识别
for (n = 0, 5) {
    int temp = n;
}

// 测试8: for-each 循环
// 预期: k,v 正确识别
list items = [1, 2, 3];
for (k, v : items) {
    int tk = k;
    int tv = v;
}

// 测试9: for-each 带类型
// 预期: key, val 正确识别
for (int key, int val : items) {
    int tk = key;
    int tv = val;
}

// 测试10: break 语句
// 预期: 正确解析
while (true) {
    break;
}

// 测试11: continue 语句
// 预期: 正确解析
while (i < 10) {
    i = i + 1;
    continue;
}

// 测试12: return 语句
// 预期: 正确解析
int testReturn() {
    return 42;
}

// 测试13: return 多值
// 预期: 正确解析
vars testMultiReturn() {
    return 1, 2;
}

// 测试14: return 无值
// 预期: 正确解析
void testVoidReturn() {
    return;
}

// 测试15: defer 语句
// 预期: 正确解析
void testDefer() {
    defer {
        int cleanup = 1;
    }
}

// 测试16: 嵌套控制流
// 预期: 所有变量正确识别
for (int outer = 0, 10) {
    if (outer == 5) {
        int inner = outer;
    }
}

// 测试17: 空语句
// 预期: 正确解析
;

// 测试18: 代码块
// 预期: 正确解析
{
    int blockVar = 1;
}
