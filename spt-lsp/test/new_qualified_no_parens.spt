// 测试: 类 - new A.B 不带括号
// 语法: newExp -> NEW qualifiedIdentifier (OP arguments? CP)?
// 描述: 测试new表达式不带括号实例化命名空间中的类

class Inner {
    int value = 100;
}

map<any, any> NS = {};
NS.Inner = Inner;
Inner abc = NS.Inner();
abc.value = 10;
assert(abc.value == 100, "obj.value should be 100");

print("new_qualified_no_parens tests passed!");
