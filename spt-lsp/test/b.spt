export class Person {
    string name;
    int age;

    void __init(string name, int age) {
        this.name = name;
        this.age = age;
    }

    void sayHello() {
        print("Hello from b.spt: " .. this.name);
    }

    int getAge() {
        return this.age;
    }
}

export int add(int a, int b) {
    return a + b;
}
