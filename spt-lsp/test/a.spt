//a.spt

class Person {
    string name;
    int age;

    void __init(string name, int age) {
        this.name = name;
        this.age = age;
    }

    void sayHello() {
        print("Hello, I'm " .. this.name .. ", age " .. this.age);
    }

    int getAge() {
        return this.age;
    }
}

int add(int a, int b) {
    return a + b;
}

int main() {
    auto p = new Person("Alice", 25);
    p.sayHello();
    print("Age: " .. p.getAge());
    
    int result = add(3, 4);
    print("3 + 4 = " .. result);
    return 0;
}

main();
