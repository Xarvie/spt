[18:47:52.319] [RECV] {"jsonrpc":"2.0","method":"textDocument/didOpen","params":{"textDocument":{"uri":"file:///c%3A/Users/ftp/Desktop/spt/spt-lsp/test/test_phase4.spt","languageId":"sptscript","version":1,"text":"// Phase 4 模块与导入测试\n\n// 测试1: 导入整个模块\n// 预期: 正确解析，utils 符号可跳转\nimport * as utils from \"utils\";\n\n// 测试2: 导入特定名称\n// 预期: 正确解析，foo, bar 符号可跳转\nimport { foo, bar } from \"my_module\";\n\n// 测试3: 导入并重命名\n// 预期: 正确解析，myFoo, myBar 符号可跳转\nimport { foo as myFoo, bar as myBar } from \"my_module\";\n\n// 测试4: 使用导入的模块函数\n// 预期: 点击 foo 可跳转到 my_module.spt 中的定义\nvoid testImportedFunction() {\n    int result1 = foo(5);\n    int result2 = bar(10);\n    int result3 = myFoo(3);\n}\n\n// 测试5: 使用导入的模块\n// 预期: 点击 util_add 可跳转到 utils.spt 中的定义\nvoid testImportedModule() {\n    int sum = utils.util_add(1, 2);\n    int diff = utils.util_sub(5, 3);\n}\n\n// 测试5.5: 使用导入的类\n// 预期: 点击 MyModuleClass 可跳转到 my_module.spt 中的定义\nimport { MyModuleClass } from \"my_module\";\n\nvoid testImportedClass() {\n    MyModuleClass obj;\n    obj.setId(100);\n    int id = obj.getId();\n}\n\n// 测试6: 泛型类型\n// 预期: hover显示 list<int>\nlist<int> intList = [1, 2, 3];\n\n// 测试7: 泛型类型\n// 预期: hover显示 map<str, int>\nmap<str, int> strIntMap = { a: 1, b: 2 };\n\n// 测试8: 嵌套泛型\n// 预期: hover显示 list<list<int>>\nlist<list<int>> nestedList = [[1, 2], [3, 4]];\n\n// 测试9: 类定义\nclass MyClass {\n    int x;\n    int y;\n    \n    void setPos(int px, int py) {\n        this.x = px;\n        this.y = py;\n    }\n    \n    int getX() {\n        return this.x;\n    }\n}\n\n// 测试10: 类实例化和字段访问\nvoid testClass() {\n    MyClass obj;\n    obj.setPos(10, 20);\n    int val = obj.getX();\n}\n\n// 测试11: 静态字段\nclass Counter {\n    static int count = 0;\n    \n    void increment() {\n        Counter.count = Counter.count + 1;\n    }\n}\n\n// 测试12: const 字段\nclass Constants {\n    const int MAX = 100;\n    const str NAME = \"test\";\n}\n\n// 测试13: 导出函数\nexport int add(int a, int b) {\n    return a + b;\n}\n\n// 测试14: 导出类\nexport class ExportedClass {\n    int value;\n    \n    int getValue() {\n        return this.value;\n    }\n}\n\n// 测试15: Map 字面量\nmap<str, str> stringMap = {\n    name: \"John\",\n    age: \"30\",\n    city: \"NYC\"\n};\n\n// 测试16: List 操作\nlist<str> names = [\"Alice\", \"Bob\", \"Charlie\"];\n\n// 测试17: 复杂表达式\nint compute(int a, int b) {\n    return (a + b) * 2 - a / b;\n}\n"}}}
